# === Без ключа (рекомендуется на экзамене) ===

# Ollama — модель должна быть скачана заранее: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# llama-cpp-python — путь к .gguf файлу на диске
# LLAMA_CPP_MODEL_PATH=./models/model.gguf

# transformers — имя модели, веса скачаны заранее
# TRANSFORMERS_MODEL=ai-forever/rugpt3small_based_on_gpt2

# === С ключом (получить ЗАРАНЕЕ, не на экзамене) ===

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# GIGACHAT_CREDENTIALS=
# GIGACHAT_MODEL=GigaChat
